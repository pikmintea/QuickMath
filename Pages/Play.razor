@page "/play"
@implements IDisposable
@inject IJSRuntime JS
@inject StatsService Stats

<div class="game-wrapper">
    @if (state == GameState.Setup)
    {
        <div class="setup-screen">
            <div class="setup-scroll">
                <h2 class="setup-heading">Game Setup</h2>

                <div class="setup-section">
                    <span class="setup-label">Topic</span>
                    <div class="setup-chips">
                        @foreach (var opt in topicOptions)
                        {
                            <button class="chip @(selectedTopic == opt.Value ? "active" : "")"
                                    @onclick="() => selectedTopic = opt.Value"
                                    aria-pressed="@(selectedTopic == opt.Value)">
                                @opt.Label
                            </button>
                        }
                    </div>
                </div>

                <div class="setup-section">
                    <span class="setup-label">Mode</span>
                    <div class="setup-chips">
                        @foreach (var opt in modeOptions)
                        {
                            <button class="chip @(selectedMode == opt.Value ? "active" : "")"
                                    @onclick="() => selectedMode = opt.Value"
                                    aria-pressed="@(selectedMode == opt.Value)">
                                @opt.Label
                            </button>
                        }
                    </div>
                    @if (selectedMode == GameMode.Custom)
                    {
                        <div class="setup-inline">
                            <input class="setup-num" type="number" @bind="customCount" min="5" max="100" aria-label="Custom question count" />
                            <span class="setup-inline-label">questions</span>
                        </div>
                    }
                </div>

                <div class="setup-section">
                    <span class="setup-label">Difficulty</span>
                    <div class="setup-chips">
                        @foreach (var opt in diffOptions)
                        {
                            <button class="chip @(selectedDifficulty == opt.Value ? "active" : "")"
                                    @onclick="() => selectedDifficulty = opt.Value"
                                    aria-pressed="@(selectedDifficulty == opt.Value)">
                                @opt.Label
                            </button>
                        }
                    </div>
                    <div class="setup-diff-note">@difficultyNote</div>
                </div>

                <button class="start-btn" @onclick="StartGame">PLAY</button>
            </div>
        </div>
    }
    else if (state == GameState.Countdown)
    {
        <div class="countdown-screen">
            <div class="countdown-number" @key="@CountdownNumber" aria-live="assertive">
                @if (CountdownNumber > 0)
                {
                    <text>@CountdownNumber</text>
                }
                else
                {
                    <span class="go-text">GO!</span>
                }
            </div>
        </div>
    }
    else if (state == GameState.GameOver)
    {
        <div class="gameover-screen">
            <div class="gameover-title">GAME OVER</div>
            <div class="final-stats">
                <div class="final-stat">
                    <div class="final-stat-value score-value">@Score</div>
                    <div class="final-stat-label">SCORE</div>
                </div>
                <div class="final-stat">
                    <div class="final-stat-value streak-value">@BestStreak</div>
                    <div class="final-stat-label">BEST STREAK</div>
                </div>
                <div class="final-stat">
                    <div class="final-stat-value qs-value">@QuestionsAnswered</div>
                    <div class="final-stat-label">SOLVED</div>
                </div>
            </div>
            <button class="start-btn" @onclick="BackToSetup">SETUP</button>
            <button class="start-btn secondary" @onclick="StartGame">PLAY AGAIN</button>
        </div>
    }
    else
    {
        <div class="game-hud">
            <div class="hud-top">
                <div class="hud-score" role="status" aria-label="Score @Score">
                    <span class="hud-label">SCORE</span>
                    <span class="hud-value">@Score</span>
                </div>
                <div class="hud-streak">
                    @if (Streak >= 3)
                    {
                        <span class="streak-fire">🔥</span>
                        <span class="streak-value">x@(Streak)</span>
                    }
                </div>
                @if (showLives)
                {
                    <div class="hud-lives" role="status" aria-label="@Lives lives remaining">
                        @for (int i = 0; i < MaxLives; i++)
                        {
                            <span class="heart @(i < Lives ? "heart-full" : "heart-empty")">&#9829;</span>
                        }
                    </div>
                }
            </div>
            <div class="hud-topic-row">
                <span class="hud-topic">@CurrentTopic</span>
                <span class="hud-topic-level">
                    @modeLabel · @difficultyLabel
                </span>
            </div>
            @if (showPerQuestionTimer)
            {
                <div class="timer-track" role="status" aria-label="@TimeLeft seconds remaining">
                    <div class="timer-fill" style="width: @TimerPercent%"></div>
                    <div class="timer-text">@TimeLeft</div>
                </div>
            }
            else
            {
                <div class="timer-track total" role="status" aria-label="@TotalTimeLeft seconds remaining">
                    <div class="timer-fill" style="width: @TotalTimerPercent%"></div>
                    <div class="timer-text">@TotalTimeLeft s</div>
                </div>
            }
            <div class="question-area">
                <div class="question-box" @key="@questionKey">
                    <span class="q-num">@Number1</span>
                    <span class="q-op">@OperationSymbol</span>
                    <span class="q-num">@Number2</span>
                    <span class="q-eq">=</span>
                    <span class="q-qm">?</span>
                </div>
                <div class="input-row">
                     <input class="answer-input @(feedbackClass)"
                            type="number"
                            placeholder="?"
                            aria-label="Enter your answer"
                            @bind="UserAnswer"
                            @bind:event="oninput"
                            @ref="inputRef"
                            autofocus
                            spellcheck="false" />
                </div>
                @if (!string.IsNullOrEmpty(feedbackText))
                {
                    <div class="feedback @feedbackClass" aria-live="polite" role="status">@feedbackText</div>
                }
            </div>
            <div class="hud-bottom">
                @if (showQuestionCounter)
                {
                    <div class="q-counter">@QuestionsAnswered / @questionLimitText</div>
                }
            </div>
        </div>
    }
</div>

@code {
    enum GameState { Setup, Countdown, Playing, GameOver }
    enum TopicFilter { All, Addition, Subtraction, Multiplication, Division }
    enum GameMode { Infinite, TwentyQuestions, OneMinute, Custom }
    enum Difficulty { SuperEasy, Easy, Medium, Hard }

    // ─── Setup options ───
    TopicFilter selectedTopic = TopicFilter.All;
    GameMode selectedMode = GameMode.Infinite;
    Difficulty selectedDifficulty = Difficulty.Easy;
    int customCount = 20;

    record Chip<T>(string Label, T Value);

    Chip<TopicFilter>[] topicOptions = new[] {
        new Chip<TopicFilter>("All", TopicFilter.All),
        new Chip<TopicFilter>("+", TopicFilter.Addition),
        new Chip<TopicFilter>("−", TopicFilter.Subtraction),
        new Chip<TopicFilter>("×", TopicFilter.Multiplication),
        new Chip<TopicFilter>("÷", TopicFilter.Division),
    };

    Chip<GameMode>[] modeOptions = new[] {
        new Chip<GameMode>("Infinite", GameMode.Infinite),
        new Chip<GameMode>("20 Qs", GameMode.TwentyQuestions),
        new Chip<GameMode>("1 Min", GameMode.OneMinute),
        new Chip<GameMode>("Custom", GameMode.Custom),
    };

    Chip<Difficulty>[] diffOptions = new[] {
        new Chip<Difficulty>("Super Easy", Difficulty.SuperEasy),
        new Chip<Difficulty>("Easy", Difficulty.Easy),
        new Chip<Difficulty>("Medium", Difficulty.Medium),
        new Chip<Difficulty>("Hard", Difficulty.Hard),
    };

    string difficultyNote => selectedDifficulty switch
    {
        Difficulty.SuperEasy => "Numbers 1–10 · Reduced XP",
        Difficulty.Easy => "Numbers 1–15",
        Difficulty.Medium => "Numbers 1–25",
        Difficulty.Hard => "Numbers 1–40 · Bonus XP",
        _ => ""
    };

    // ─── Derived mode flags ───
    bool showLives => selectedMode != GameMode.OneMinute;
    bool showPerQuestionTimer => selectedMode != GameMode.OneMinute;
    bool showQuestionCounter => selectedMode is GameMode.TwentyQuestions or GameMode.Custom;
    bool hasQuestionLimit => selectedMode is GameMode.TwentyQuestions or GameMode.Custom;
    int questionLimit => selectedMode switch
    {
        GameMode.TwentyQuestions => 20,
        GameMode.Custom => customCount,
        _ => int.MaxValue
    };
    string questionLimitText => selectedMode == GameMode.Custom ? $"{customCount}" : "20";

    string modeLabel => selectedMode switch
    {
        GameMode.Infinite => "Infinite",
        GameMode.TwentyQuestions => "20 Qs",
        GameMode.OneMinute => "1 Min Rush",
        GameMode.Custom => $"{customCount} Qs",
        _ => ""
    };

    // ─── Game state ───
    GameState state = GameState.Setup;
    Random random = new();
    System.Threading.Timer? gameTimer;
    Guid gameId = Guid.NewGuid();

    int Number1;
    int Number2;
    int Answer;
    string OperationSymbol = "+";

    int Score;
    int Streak;
    int BestStreak;
    int Lives = 3;
    int MaxLives = 3;
    int TimeLeft;
    int MaxTime = 10;
    int TotalTimeLeft;
    int TotalTimeMax = 60;
    int QuestionsAnswered;
    int totalWrong;
    int baseXp = 10;

    int TimerPercent => MaxTime > 0 ? (int)((double)TimeLeft / MaxTime * 100) : 0;
    int TotalTimerPercent => TotalTimeMax > 0 ? (int)((double)TotalTimeLeft / TotalTimeMax * 100) : 0;
    int CountdownNumber = 3;
    string difficultyLabel = "EASY";
    string questionKey => $"{Number1}{OperationSymbol}{Number2}";

    bool gameOverRecorded;

    string CurrentTopic => OperationSymbol switch
    {
        "+" => "Addition",
        "-" => "Subtraction",
        "×" => "Multiplication",
        "÷" => "Division",
        _ => "Math"
    };

    string? feedbackText;
    string? feedbackClass;
    string? userAnswer;
    ElementReference inputRef;

    string UserAnswer
    {
        get => userAnswer ?? "";
        set
        {
            userAnswer = value;
            if (string.IsNullOrEmpty(userAnswer)) return;
            if (state != GameState.Playing) return;
            if (int.TryParse(userAnswer, out int ans) && ans == Answer)
            {
                HandleCorrect();
            }
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender || state == GameState.Setup)
        {
            _ = FocusInput();
        }
    }

    void BackToSetup()
    {
        gameTimer?.Dispose();
        gameTimer = null;
        state = GameState.Setup;
    }

    async Task FocusInput()
    {
        await Task.Delay(100);
        try { await inputRef.FocusAsync(); } catch { }
    }

    void StartGame()
    {
        Score = 0;
        Streak = 0;
        BestStreak = 0;
        Lives = MaxLives;
        QuestionsAnswered = 0;
        totalWrong = 0;
        userAnswer = null;
        feedbackText = null;
        feedbackClass = null;
        gameOverRecorded = false;
        gameId = Guid.NewGuid();

        (baseXp, difficultyLabel) = selectedDifficulty switch
        {
            Difficulty.SuperEasy => (5, "SUPER EASY"),
            Difficulty.Easy => (10, "EASY"),
            Difficulty.Medium => (15, "MEDIUM"),
            Difficulty.Hard => (25, "HARD"),
            _ => (10, "EASY")
        };

        MaxTime = selectedDifficulty switch
        {
            Difficulty.SuperEasy => 15,
            Difficulty.Easy => 12,
            Difficulty.Medium => 10,
            Difficulty.Hard => 7,
            _ => 12
        };

        state = GameState.Countdown;
        CountdownNumber = 3;
        gameTimer?.Dispose();
        gameTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                if (state != GameState.Countdown) return;
                var prev = CountdownNumber;
                CountdownNumber--;
                if (prev > 0 && CountdownNumber > 0)
                {
                    _ = PlaySound("countdownTick");
                }
                if (CountdownNumber < 0)
                {
                    state = GameState.Playing;
                    GenerateQuestion();
                    StartTimer();
                    _ = PlaySound("countdownGo");
                    _ = FocusInput();
                }
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    void StartTimer()
    {
        gameTimer?.Dispose();

        if (selectedMode == GameMode.OneMinute)
        {
            TotalTimeLeft = TotalTimeMax;
            gameTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(() =>
                {
                    if (state != GameState.Playing) return;
                    TotalTimeLeft--;
                    if (TotalTimeLeft <= 0)
                    {
                        state = GameState.GameOver;
                        gameTimer?.Dispose();
                        _ = OnGameOver();
                    }
                    StateHasChanged();
                });
            }, null, 1000, 1000);
        }
        else
        {
            TimeLeft = MaxTime;
            gameTimer = new System.Threading.Timer(async _ =>
            {
                await InvokeAsync(() =>
                {
                    if (state != GameState.Playing) return;
                    TimeLeft--;
                    if (TimeLeft <= 0)
                    {
                        HandleTimeUp();
                    }
                    StateHasChanged();
                });
            }, null, 1000, 1000);
        }
    }

    void HandleTimeUp()
    {
        if (state != GameState.Playing) return;
        totalWrong++;
        if (showLives)
        {
            Lives--;
        }
        Streak = 0;
        QuestionsAnswered++;
        int snapScore = Score;
        int snapStreak = BestStreak;
        _ = Stats.UpdatePartialAsync(0, 1, 0, snapScore, snapStreak);
        feedbackText = "⏰ Time's up!";
        feedbackClass = "wrong";
        _ = PlaySound("wrong");
        _ = ClearFeedbackAfterDelay();

        bool dead = showLives && Lives <= 0;
        bool limitReached = hasQuestionLimit && QuestionsAnswered >= questionLimit;

        if (dead || limitReached)
        {
            state = GameState.GameOver;
            gameTimer?.Dispose();
            _ = PlaySound("gameOver");
            _ = OnGameOver();
        }
        else
        {
            userAnswer = null;
            GenerateQuestion();
            StartTimer();
            _ = FocusInput();
        }
    }

    void PickMaxNum(out int maxNum, out int opCount)
    {
        int max, ops;
        switch (selectedDifficulty)
        {
            case Difficulty.SuperEasy: max = 10; ops = 1; break;
            case Difficulty.Easy: max = 15; ops = 2; break;
            case Difficulty.Medium: max = 25; ops = 3; break;
            default: max = 40; ops = 4; break;
        }
        maxNum = max;
        opCount = ops;
    }

    bool IsOpAllowed(int opIndex)
    {
        if (selectedTopic == TopicFilter.All) return true;
        return (int)selectedTopic - 1 == opIndex;
    }

    void GenerateQuestion()
    {
        int maxNum, opCount;
        PickMaxNum(out maxNum, out opCount);

        var allowed = new List<int>();
        for (int i = 0; i < opCount; i++)
            if (IsOpAllowed(i)) allowed.Add(i);

        if (allowed.Count == 0) allowed.Add(0);

        int op = allowed[random.Next(allowed.Count)];

        switch (op)
        {
            case 0: GenerateAddition(maxNum); break;
            case 1: GenerateSubtraction(maxNum); break;
            case 2: GenerateMultiplication(maxNum); break;
            case 3: GenerateDivision(maxNum); break;
        }

        feedbackText = null;
        feedbackClass = null;
    }

    void GenerateAddition(int max)
    {
        Number1 = random.Next(1, max + 1);
        Number2 = random.Next(1, max + 1);
        Answer = Number1 + Number2;
        OperationSymbol = "+";
    }

    void GenerateSubtraction(int max)
    {
        Number1 = random.Next(2, max + 1);
        Number2 = random.Next(1, Number1);
        Answer = Number1 - Number2;
        OperationSymbol = "-";
    }

    void GenerateMultiplication(int max)
    {
        int limit = Math.Min(max / 2 + 1, 13);
        Number1 = random.Next(1, limit + 1);
        Number2 = random.Next(1, limit + 1);
        Answer = Number1 * Number2;
        OperationSymbol = "×";
    }

    void GenerateDivision(int max)
    {
        int limit = Math.Min(max / 2 + 1, 13);
        Number2 = random.Next(1, limit + 1);
        Answer = random.Next(1, limit + 1);
        Number1 = Number2 * Answer;
        OperationSymbol = "÷";
    }

    void HandleCorrect()
    {
        if (state != GameState.Playing) return;
        QuestionsAnswered++;
        Streak++;
        if (Streak > BestStreak) BestStreak = Streak;

        int multiplier = Streak >= 10 ? 4 : Streak >= 7 ? 3 : Streak >= 4 ? 2 : 1;
        int points = baseXp * multiplier;

        if (multiplier > 1 && Streak >= 4 && (Streak == 4 || Streak == 7 || Streak == 10))
        {
            _ = PlaySound("streak", multiplier);
            _ = TriggerConfetti();
        }
        else
        {
            _ = PlaySound("correct");
        }

        Score += points;

        int snapScore = Score;
        int snapStreak = BestStreak;
        _ = Stats.UpdatePartialAsync(1, 0, points, snapScore, snapStreak);

        feedbackText = multiplier > 1 ? $"+{points} x{multiplier}!" : $"+{points}";
        feedbackClass = "correct";
        _ = ClearFeedbackAfterDelay();

        if (hasQuestionLimit && QuestionsAnswered >= questionLimit)
        {
            state = GameState.GameOver;
            gameTimer?.Dispose();
            _ = PlaySound("gameOver");
            _ = OnGameOver();
            return;
        }

        userAnswer = null;
        GenerateQuestion();
        _ = FocusInput();

        if (selectedMode != GameMode.OneMinute)
        {
            StartTimer();
        }
    }

    async Task ClearFeedbackAfterDelay()
    {
        await Task.Delay(700);
        try { await InvokeAsync(() => { feedbackText = null; feedbackClass = null; StateHasChanged(); }); }
        catch { }
    }

    async Task PlaySound(string kind, int? level = null)
    {
        try
        {
            switch (kind)
            {
                case "correct": await JS.InvokeVoidAsync("__sound.correct"); break;
                case "wrong": await JS.InvokeVoidAsync("__sound.wrong"); break;
                case "gameOver": await JS.InvokeVoidAsync("__sound.gameOver"); break;
                case "streak": await JS.InvokeVoidAsync("__sound.streak", level ?? 2); break;
                case "countdownTick": await JS.InvokeVoidAsync("__sound.countdownTick"); break;
                case "countdownGo": await JS.InvokeVoidAsync("__sound.countdownGo"); break;
            }
        }
        catch { }
    }

    async Task TriggerConfetti()
    {
        try { await JS.InvokeVoidAsync("__effects.confetti", 25); }
        catch { }
    }

    async Task OnGameOver()
    {
        if (gameOverRecorded) return;
        gameOverRecorded = true;
        await Stats.IncrementGamesPlayedAsync();
    }

    public void Dispose()
    {
        gameTimer?.Dispose();
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    .game-wrapper {
        font-family: 'Inter', system-ui, sans-serif;
        min-height: calc(100vh - 7rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--text);
        position: relative;
        overflow: hidden;
    }

    .game-wrapper::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--bg-page);
        background-image:
            radial-gradient(circle at 15% 30%, var(--primary-subtle) 0%, transparent 50%),
            radial-gradient(circle at 85% 70%, var(--wrong-subtle) 0%, transparent 50%);
        z-index: -2;
    }

    .game-wrapper::after {
        content: '∑  π  √  ∫  ∞  ≈  ≠  α  β  θ  Δ  2²  3³  √x  x²  ∑  π  √  ∫  ∞';
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Georgia', serif;
        font-size: clamp(8rem, 20vw, 20rem);
        font-weight: 700;
        color: var(--primary-subtle);
        letter-spacing: 0.3em;
        line-height: 1.2;
        text-align: center;
        word-break: break-all;
        z-index: -1;
        pointer-events: none;
        user-select: none;
        padding: 2rem;
    }

    /* ===== SETUP SCREEN ===== */
    .setup-screen {
        width: 100%;
        max-width: 420px;
        animation: fadeIn 0.4s ease;
        position: relative;
    }

    .setup-scroll {
        max-height: calc(100vh - 10rem);
        overflow-y: auto;
        padding: 0.25rem 0;
    }

    .setup-heading {
        font-family: 'Georgia', 'Times New Roman', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--text);
        text-align: center;
        margin: 0 0 1.5rem;
    }

    .setup-section {
        margin-bottom: 1.25rem;
    }

    .setup-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.5rem;
    }

    .setup-chips {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .chip {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        border-radius: 0.4rem;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-secondary);
        cursor: pointer;
        transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }

    .chip:hover {
        border-color: var(--primary);
        color: var(--text);
    }

    .chip.active {
        background: var(--primary);
        border-color: var(--primary);
        color: #fff;
    }

    .setup-inline {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.6rem;
    }

    .setup-num {
        font-family: 'Georgia', 'Times New Roman', serif;
        font-size: 1rem;
        font-weight: 600;
        width: 70px;
        padding: 0.3rem 0.5rem;
        text-align: center;
        border: 1px solid var(--border);
        border-radius: 0.35rem;
        background: var(--bg-input);
        color: var(--text);
        outline: none;
        -moz-appearance: textfield;
    }

    .setup-num::-webkit-outer-spin-button,
    .setup-num::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .setup-num:focus {
        border-color: var(--primary);
    }

    .setup-inline-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    .setup-diff-note {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 0.4rem;
        font-style: italic;
    }

    .start-btn {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        padding: 0.75rem 2.5rem;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        color: #fff;
        background: var(--primary);
        box-shadow: 0 2px 8px rgba(59, 130, 246, 0.25);
        transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
        width: 100%;
        display: block;
    }

    .start-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
        background: var(--primary-hover);
    }

    .start-btn:active {
        transform: translateY(0);
    }

    .start-btn.secondary {
        background: var(--bg-card);
        color: var(--text);
        border: 1px solid var(--border);
        box-shadow: none;
        margin-top: 0.5rem;
        font-size: 0.9rem;
        padding: 0.5rem;
        width: auto;
        display: inline-block;
    }

    .start-btn.secondary:hover {
        background: var(--bg-hover);
        border-color: var(--text-muted);
        transform: none;
        box-shadow: none;
    }

    /* ===== COUNTDOWN ===== */
    .countdown-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 50vh;
        animation: fadeIn 0.2s ease;
    }

    .countdown-number {
        font-family: 'Georgia', 'Times New Roman', serif;
        font-size: 7rem;
        font-weight: 700;
        color: var(--countdown-color);
        animation: countPop 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
