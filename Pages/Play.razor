@page "/play"

<PageTitle>Math Game</PageTitle>

<div class="game-container">
    <h1>Fast Addition</h1>

    <div class="question">
        @Number1 + @Number2 = ?
    </div>

    <input class="answer-input"
           type="number"
           placeholder="Your answer..."
           @bind="UserAnswer"
           @bind:event="oninput" />

    <div class="score">
        XP: @Score
    </div>
</div>

<style>
    .game-container {
        max-width: 400px;
        margin: 50px auto;
        padding: 25px;
        text-align: center;
        border-radius: 12px;
        background: #f4f4f4;
        box-shadow: 0 4px 10px rgba(0,0,0,.15);
        font-family: Arial, sans-serif;
    }

    .question {
        font-size: 42px;
        font-weight: bold;
        margin: 25px 0;
    }

    .answer-input {
        width: 100%;
        padding: 12px;
        font-size: 24px;
        text-align: center;
        border: 2px solid #ccc;
        border-radius: 8px;
        outline: none;
    }

        .answer-input:focus {
            border-color: #4CAF50;
        }

    .score {
        margin-top: 20px;
        font-size: 24px;
        font-weight: bold;
        color: #4CAF50;
    }
</style>

@code {
    Random random = new();

    int Number1;
    int Number2;
    int Score;

    string userAnswer = "";

    string UserAnswer
    {
        get => userAnswer;
        set
        {
            userAnswer = value;

            if (int.TryParse(userAnswer, out int answer))
            {
                if (answer == Number1 + Number2)
                {
                    Score++;
                    userAnswer = "";
                    GenerateQuestion();
                }
            }
        }
    }

    protected override void OnInitialized()
    {
        GenerateQuestion();
    }

    void GenerateQuestion()
    {
        Number1 = random.Next(1, 21);
        Number2 = random.Next(1, 21);
    }
}