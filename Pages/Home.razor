@page "/"
@inject NavigationManager Navigation

<PageTitle>Quick Math</PageTitle>

<div class="home-wrapper">
    <div class="home-content">
        <div class="home-title">
            <span class="hl-text">Quick Math</span>
        </div>
        <p class="home-desc">
            Mental arithmetic practice — fast.<br>
            Addition, subtraction, multiplication, division.
        </p>
        <div class="home-features">
            <span class="home-feat">+ Addition</span>
            <span class="home-feat">− Subtraction</span>
            <span class="home-feat">× Multiplication</span>
            <span class="home-feat">÷ Division</span>
        </div>
        <button @onclick="StartGame" class="home-btn">
            Start Practicing
        </button>
    </div>
</div>

@code {
    void StartGame()
    {
        Navigation.NavigateTo("/QuickMath/play");
    }
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    .home-wrapper {
        min-height: calc(100vh - 7rem);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .home-wrapper::before {
        content: '';
        position: absolute;
        inset: 0;
        background: var(--bg-page);
        background-image:
            radial-gradient(circle at 15% 30%, var(--primary-subtle) 0%, transparent 50%),
            radial-gradient(circle at 85% 70%, var(--wrong-subtle) 0%, transparent 50%);
        z-index: -2;
    }

    .home-wrapper::after {
        content: '∑  π  √  ∫  ∞  ≈  ≠  α  β  θ  Δ  2²  3³  √x  x²  ∑  π  √  ∫  ∞';
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Georgia', serif;
        font-size: clamp(8rem, 20vw, 20rem);
        font-weight: 700;
        color: var(--primary-subtle);
        letter-spacing: 0.3em;
        line-height: 1.2;
        text-align: center;
        word-break: break-all;
        z-index: -1;
        pointer-events: none;
        user-select: none;
        padding: 2rem;
    }

    .home-content {
        text-align: center;
        animation: hFadeIn 0.6s ease;
        position: relative;
    }

    .home-content::before {
        content: '∑  π  √  ∫  ∞  ≈  ≠  α  β  θ  Δ';
        position: absolute;
        top: -3rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: 'Georgia', serif;
        font-size: 0.85rem;
        color: var(--primary-subtle);
        letter-spacing: 0.4em;
        white-space: nowrap;
    }

    .home-title {
        font-family: 'Georgia', 'Times New Roman', serif;
        font-size: 3.2rem;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.5rem;
    }

    .home-desc {
        font-size: 1rem;
        color: var(--text-secondary);
        margin-bottom: 2rem;
        font-style: italic;
        line-height: 1.6;
    }

    .home-btn {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 1.1rem;
        font-weight: 600;
        padding: 0.85rem 3rem;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        color: #fff;
        background: var(--primary);
        box-shadow: 0 2px 8px rgba(59, 130, 246, 0.25);
        transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    }

    .home-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(59, 130, 246, 0.35);
        background: var(--primary-hover);
    }

    .home-btn:active {
        transform: translateY(0);
    }

    .home-features {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .home-feat {
        font-size: 0.8rem;
        color: var(--text-secondary);
        background: var(--bg-card);
        padding: 0.35rem 0.9rem;
        border-radius: 0.25rem;
        border: 1px solid var(--border);
    }

    @@keyframes hFadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 640px) {
        .home-title { font-size: 2rem; }
        .home-desc { font-size: 0.9rem; }
        .home-btn { font-size: 1rem; padding: 0.7rem 2rem; }
        .home-feat { font-size: 0.75rem; padding: 0.25rem 0.6rem; }
    }
</style>
